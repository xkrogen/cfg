# Azure VM shortcuts

alias azurevm='ssh -t azurevm "tmux new -A -s session"'
alias azvm-clip='ssh azurevm "DISPLAY=:0 xclip -o"'
alias azvm-cb='azvm-clip | pbcopy'

function azvm-rsync() {
    rsync --inplace -avzh --exclude '/**/target/***' --exclude '/**/build/***' --exclude '/config/external/***' --exclude '/.gradle/***' --exclude '/.mypy_cache/***' --exclude '/.git/worktrees/*/gitdir' --exclude '/*/.git' --include='.git/' --exclude='.git' --exclude /'**/azkaban/***' . azurevm:"${PWD/#$HOME\//}"
}

function forcepush_azurevm() {
  pwd_rel="$(pwd | sed "s|^$HOME/||")"
  echo "cd $pwd_rel && echo 'RUNNING COMMANDS IN:' && pwd && git checkout -- . && (git branch -D forcepushtmp 2>/dev/null || true) && git checkout -b forcepushtmp" | ssh -T azurevm
  git push --force azurevm "$(git branch --show-current | tr -d '\n')"
  echo "cd $pwd_rel && git checkout $(git branch --show-current | tr -d '\n') && git branch -D forcepushtmp" | ssh -T azurevm
}

function forcepush_azurevm_hard() {
  pwd_rel="$(pwd | sed "s|^$HOME/||")"
  echo "cd $pwd_rel && echo 'RUNNING COMMANDS IN:' && pwd && git restore --staged . && git checkout -- . && git clean -fd && (git branch -D forcepushtmp 2>/dev/null || true) && git checkout -b forcepushtmp" | ssh -T azurevm
  git push --force azurevm "$(git branch --show-current | tr -d '\n')"
  echo "cd $pwd_rel && git checkout $(git branch --show-current | tr -d '\n') && git branch -D forcepushtmp" | ssh -T azurevm
}

# Set up auth for JIRA CLI https://github.com/ankitpokhrel/jira-cli
alias jira='JIRA_API_TOKEN=$(cat ~/.config/.jira/.token) JIRA_AUTH_TYPE=bearer jira'

# Captain namespace setup — pass IDE as argument (e.g., captain_ns_setup claude)
function captain_ns_setup() {
    local ide="${1:?Usage: captain_ns_setup <ide>}"
    export IDE="$ide"
    for ns in data github inlogs org-tree google; do
        captain add --"$ide" "$ns"
    done
}

# Re-auth all services
function reauth() {
    for auth in datahub search darwin trino airflow; do
        captain setup "$auth"
    done
    trino auth --sso
    darwin auth setup
    az login
}


# Rust installation setup guidelines as recommended by 'mint toolchains rust'
export PATH="$HOME/.cargo/bin:$PATH"
export RUSTUP_DIST_SERVER=https://artifactory.corp.linkedin.com:8083/artifactory/rustup-remote
export RUSTUP_UPDATE_ROOT=https://artifactory.corp.linkedin.com:8083/artifactory/rustup-remote/rustup

# Trino aliases

function get_trino_version() {
    grep pom.xml -e "<artifactId>trino-root</artifactId>" -A1 | grep "<version>" | sed -E 's/^.+>([0-9]+).+$/\1/'
}

function get_trino_modules() {
    for arg in "$@"; do
        if [ "$arg" = "-pl" ]; then
            echo ""
            return 0
        fi
    done

    trino_version="$(get_trino_version | tr -d '\n')"

    if [ "$trino_version" = "406" ]; then
        default_modules='!docs,!core/trino-server,!core/trino-server-core,!core/trino-server-main'
    elif [ "$trino_version" = "446" ]; then
        default_modules='!docs,!core/trino-server,!core/trino-server-rpm,!core/trino-server-main,!service/trino-proxy,!service/trino-verifier,!testing/trino-benchto-benchmarks'
    elif [ "$trino_version" -gt "446" ]; then
        default_modules='!docs,!core/trino-server,!core/trino-server-core,!core/trino-server-main,!service/trino-proxy,!service/trino-verifier,!testing/trino-benchto-benchmarks'
    else
        echo "Unsupported Trino version: $trino_version"
        return 1
    fi
    echo "$default_modules"
}

function mvnw-build() {
    mvn_modules=$(get_trino_modules "$@")
    if [ $? -ne 0 ]; then
        return 1
    elif [ "$mvn_modules" = "" ]; then
        modules_args=()
    else
        modules_args=("-pl" "$mvn_modules")
    fi
    # if args don't contain something starting with '-Dtest', then add -DskipTests
    skip_tests_args=("-DskipTests")
    for arg in "$@"; do
        if [[ "$arg" == -Dtest* ]]; then
            skip_tests_args=()
            break
        fi
    done
    # if args don't contain '-T' arg, then add '-T 2C' to use 2 thread per CPU core
    threads_args=("-T" "2C")
    for arg in "$@"; do
        if [[ "$arg" == -T* ]]; then
            threads_args=()
            break
        fi
    done
    # if args don't contain '-U' arg, then add '--no-snapshot-updates'
    updates_args=("-nsu")
    for arg in "$@"; do
        if [[ "$arg" == "-U" ]]; then
            updates_args=()
            break
        fi
    done

    # -Perrorprone-compiler \
    ./mvnw install \
        "${modules_args[@]}" \
        "${skip_tests_args[@]}" "${threads_args[@]}" "${updates_args[@]}" \
        -Dmaven.javadoc.skip=true -Dmaven.source.skip=true -Dair.check.skip-all=true \
        -Dskip.npm -Dskip.yarn \
        "$@"
}

function mvnw-build-validate() {
    mvnw-build "$@" && ./mvnw validate
}

# RDev / picli (Airflow) Aliases
#
# All `rdev-*` / `picli-*` helpers below take an optional MP name as their first
# argument. When omitted, they default to $(basename $(pwd)) so running them from
# inside an MP checkout still works. Examples:
#   rdev-ssh                     # from ~/dev/trino-context, attaches to its rdev
#   rdev-ssh trino-context       # same result, from any cwd
#   rdev-url trino-cli http      # look up the http port on trino-cli's rdev
#   rdev-url "" http             # same, but MP defaults to cwd basename

function rdev-current() {
    local mp="${1:-$(basename "$(pwd)")}"
    rdev ls | grep -E "^ ${mp}/" | cut -d" " -f 2
}

# Create a rdev and block until it's fully provisioned:
#   1. `rdev create` — spins up the environment.
#   2. wait for rdev's dotfiles installer to finish (it gets SIGKILLed and
#      retries; the log line "Installed dotfiles successfully" is our signal).
#   3. drive rdev_finish_setup end-to-end by piping its command through
#      `rdev ssh -d`. That also refreshes rdev's auth state.
#   4. verify the "build" tmux session is up on linuxbrew tmux.
# After this returns, `rdev-tmux` will always attach cleanly.
#
# All args pass through to `rdev create`, so:
#   rdev-create trino-cli
#   rdev-create ekrogen-ctx --context-repo
function rdev-create() {
    local mp="$1"
    [ -z "$mp" ] && { echo "usage: rdev-create <mp> [rdev create args...]" >&2; return 1; }

    echo "[rdev-create] creating $mp..."
    rdev create "$@" || return 1

    local name
    name="$(rdev-current "$mp")"
    [ -z "$name" ] && { echo "[rdev-create] couldn't locate rdev for $mp after create" >&2; return 1; }
    echo "[rdev-create] created $name; waiting for dotfiles installer..."

    # Wait (up to ~10 minutes) for rdev's dotfiles installer to finish. The
    # installer is known to SIGKILL and retry — "Installed dotfiles
    # successfully" is the last log line when it finally wins.
    local alias_under="${name//\//_}"
    local i
    for i in $(seq 1 60); do
        if echo exit | rdev ssh -d "$name" 2>/dev/null | grep -q "ready to use"; then
            if ssh -o BatchMode=yes "$alias_under" 'grep -q "Installed dotfiles successfully" ~/dotfiles-install.log' 2>/dev/null; then
                echo "[rdev-create] dotfiles installer done."
                break
            fi
        fi
        [ "$i" -eq 60 ] && { echo "[rdev-create] timed out waiting for dotfiles installer" >&2; return 1; }
        sleep 10
    done

    echo "[rdev-create] running rdev_finish_setup (cfgli clone, brew, claude code, etc)..."
    # Synchronously run finish-setup on the rdev. zsh -ilc so .zshrc sources
    # everything and RDEV_ID / PRODUCT_NAME / TMUX_TMPDIR are in scope.
    ssh -t "$alias_under" 'zsh -ilc "bash ~/ekrogen-cfg-overlay/.cfg/scripts/rdev_finish_setup.sh"' \
        || { echo "[rdev-create] rdev_finish_setup failed" >&2; return 1; }

    echo "[rdev-create] verifying cfgli + claude-code installed..."
    if ! ssh -o BatchMode=yes "$alias_under" '[ -d "$HOME/.cfg.li.git" ] && [ -x "$HOME/.local/bin/claude" ]' 2>/dev/null; then
        echo "[rdev-create] post-setup checks failed: cfgli or claude binary missing" >&2
        return 1
    fi

    echo "[rdev-create] $name is fully provisioned. Run \`rdev-tmux $mp\` to attach."
}

function rdev-create-docker() { rdev-create "$1" --enable-docker "${@:2}"; }

function rdev-ssh()     { rdev ssh -d "$(rdev-current "$1")"; }
function rdev-deletef() { rdev delete -f "$(rdev-current "$1")"; }
# Attach to our own "rdev" tmux session — a dedicated session we own,
# separate from rdev's auto-spawned "build" session. We intentionally
# use linuxbrew tmux 3.6a on its DEFAULT socket (/tmp/tmux-<uid>/default),
# not /etc/rdev/tmux. Reasons:
#   - rdev's init plants /usr/bin/tmux 3.2a on /etc/rdev/tmux. If we put
#     our 3.6a server on the same socket dir, and the pod ever restarts,
#     the 3.2a server comes back and our 3.6a client can't attach
#     (protocol mismatch → "open terminal failed: not a terminal").
#   - With distinct sockets, the two servers never collide: the build
#     session on /etc/rdev/tmux is rdev's business, the rdev session on
#     /tmp is ours. Pod restarts wipe both, but our probe just recreates
#     the rdev session idempotently on next connect.
#
# Steps:
#   1. `echo exit | rdev ssh -d <name>` refreshes rdev auth/key state
#      and wakes a stopped pod; exits immediately on EOF.
#   2. In one ssh, probe cfgli and ensure our rdev session exists
#      (creates it if the linuxbrew server is new or the session is gone
#      — covers fresh rdevs AND pod restarts).
#   3. If cfgli is missing, run rdev_finish_setup first.
#   4. Attach via ssh -tt. We use a single-string remote command (not
#      `-- bash -c ...`), so sshd's default login shell gets the command
#      and `exec tmux ...` replaces the shell process cleanly on the
#      sshd-allocated pty.
function rdev-tmux() {
    local name="$(rdev-current "$1")"
    [ -z "$name" ] && { echo "no rdev found for MP ${1:-$(basename "$(pwd)")}" >&2; return 1; }
    local alias_under="${name//\//_}"

    # `rdev ssh` (not raw ssh) is what triggers rdev's credential upload /
    # key refresh — raw ssh via the ~/.ssh/config alias skips that step, so
    # kerberos / devcert state on the rdev goes stale. `echo exit | rdev ssh
    # -d` logs in and drops out immediately on stdin EOF, letting the CLI
    # run its creds sync before we attach via raw ssh for tmux.
    echo exit | rdev ssh -d "$name"

    # Probe cfgli + linuxbrew + ephemeral-setup sentinel + ensure the rdev
    # session exists on the linuxbrew-default socket in a single ssh round
    # trip. We DO NOT set TMUX_TMPDIR here — we want /tmp/tmux-<uid>/default,
    # away from rdev's 3.2a server.
    #
    # Why three separate signals (cfgli / brew / ephemeral)?
    #   - cfgli      lives under $HOME and survives pod restart. Missing only
    #                on truly fresh rdevs.
    #   - linuxbrew  lives under /home/linuxbrew, which is on a tmpfs-style
    #                volume that gets WIPED on Shutdown Saving restart. So
    #                cfgli can be present (no first-time provisioning needed)
    #                but the tmux binary we're about to invoke can be gone.
    #                Treat this the same as cfgli=no: re-run finish-setup,
    #                which calls setup.sh → reinstalls brew + tmux.
    #   - ephemeral  /var/tmp sentinel for tools outside $HOME (GULL pkgs,
    #                trino-cli, captain shell wrapper) that the every-boot
    #                phase of init_rdev_tools.sh re-lays. Lighter than full
    #                finish-setup.
    local probe
    probe=$(ssh -o ControlPath=none -o BatchMode=yes "$alias_under" '
        set -e
        if [ ! -d "$HOME/.cfg.li.git" ]; then
            echo "cfgli=no"; exit 0
        fi
        if [ ! -x /home/linuxbrew/.linuxbrew/bin/tmux ]; then
            echo "brew=no"; exit 0
        fi
        if [ ! -f /var/tmp/.rdev_ephemeral_setup_done ]; then
            echo "ephemeral=no"
        fi
        unset TMUX_TMPDIR
        BREW_TMUX=/home/linuxbrew/.linuxbrew/bin/tmux
        if ! "$BREW_TMUX" has-session -t rdev 2>/dev/null; then
            "$BREW_TMUX" new-session -d -s rdev -c "$HOME/${PRODUCT_NAME:-}"
        fi
        echo "cfgli=yes"
    ' 2>&1)
    local probe_rc=$?

    if [ $probe_rc -ne 0 ]; then
        echo "[rdev-tmux] ssh probe failed (rc=$probe_rc): $probe" >&2
        return 1
    fi

    if echo "$probe" | grep -qE "cfgli=no|brew=no"; then
        if echo "$probe" | grep -q "brew=no"; then
            echo "[rdev-tmux] linuxbrew missing (likely Shutdown Saving wiped it); re-running rdev_finish_setup..."
        else
            echo "[rdev-tmux] cfgli missing; running first-time provisioning..."
        fi
        ssh -tt -o ControlPath=none "$alias_under" \
            'zsh -ilc "bash ~/ekrogen-cfg-overlay/.cfg/scripts/rdev_finish_setup.sh"' \
            || { echo "[rdev-tmux] finish-setup failed; refusing to attach" >&2; return 1; }
        # finish-setup already ran init_rdev_tools.sh all, so ephemeral tools
        # + linuxbrew are in place. Create our tmux session (finish-setup no
        # longer touches it — that's rdev-tmux's job).
        ssh -o ControlPath=none -o BatchMode=yes "$alias_under" '
            unset TMUX_TMPDIR
            BREW_TMUX=/home/linuxbrew/.linuxbrew/bin/tmux
            if ! "$BREW_TMUX" has-session -t rdev 2>/dev/null; then
                "$BREW_TMUX" new-session -d -s rdev -c "$HOME/${PRODUCT_NAME:-}"
            fi
        ' >/dev/null 2>&1 || { echo "[rdev-tmux] post-setup session create failed" >&2; return 1; }
    elif echo "$probe" | grep -q "ephemeral=no"; then
        echo "[rdev-tmux] overlayfs wipe detected (no /var/tmp sentinel); restoring ephemeral tools..."
        # zsh -ilc so ~/.zshrc is sourced and RDEV_ID / PRODUCT_NAME / PATH
        # (including brew and captain) are in scope. every_boot is idempotent
        # and logs to ~/.rdev_init_tools.log.
        ssh -tt -o ControlPath=none "$alias_under" \
            'zsh -ilc "bash ~/.cfg/scripts/init_rdev_tools.sh every_boot"' \
            || echo "[rdev-tmux] WARN: every_boot returned non-zero; proceeding to attach anyway (see ~/.rdev_init_tools.log on rdev)." >&2
    fi

    # Attach. `unset TMUX_TMPDIR` strips the /etc/rdev/tmux value that
    # rdev's /etc/profile.d sets, so we hit the linuxbrew 3.6a server on
    # /tmp instead of rdev's 3.2a server. `exec tmux` replaces the remote
    # login shell on the sshd-allocated pty — passing the command as a
    # single string (not `-- bash -c`) makes the login shell the direct
    # parent that exec's tmux, so tmux inherits the pty correctly.
    ssh -tt "$alias_under" \
        'unset TMUX_TMPDIR; exec /home/linuxbrew/.linuxbrew/bin/tmux -u attach -t rdev'
}

# Copy the current macOS clipboard image to the rdev's /tmp and put the remote
# path on the local clipboard (so you can paste it into Claude, a tmux pane on
# the rdev, etc.). Mirrors ~/.raycast-scripts/clipboard-to-azurevm.sh. Uses the
# underscore alias form since scp can't parse slash-form aliases.
function rdev-paste-img() {
    local name="$(rdev-current "$1")"
    [ -z "$name" ] && { echo "no rdev found for MP ${1:-$(basename "$(pwd)")}" >&2; return 1; }
    local alias_underscore="${name//\//_}"
    local filename="clipboard_$(date +%Y%m%d_%H%M%S).png"
    local local_tmp="/tmp/clipboard.png"
    # reap old clipboard pastes on the rdev (>1 day) to avoid /tmp bloat
    ssh "$alias_underscore" 'find /tmp -maxdepth 1 -name "clipboard_*.png" -mtime +1 -delete' 2>/dev/null
    pngpaste "$local_tmp" \
        && scp -q "$local_tmp" "$alias_underscore:/tmp/$filename" \
        && printf '/tmp/%s' "$filename" | pbcopy \
        && echo "Sent /tmp/$filename to $name (remote path copied to clipboard)" \
        || { echo "rdev-paste-img failed" >&2; return 1; }
}

alias picli-create='picli test create'
function picli-upload()       { picli test upload "$(rdev-current "$1")"; }
function picli-build-upload() { mint build && mint release && picli-upload "$1"; }
function picli-login()        { picli test login -g holdem -m ssh "$(rdev-current "$1")" --skip-port-forward; }

function rdev-url() {
    # Usage: rdev-url [mp] [port_name]
    # mp defaults to $(basename "$PWD"). Pass "" to use the default while still
    # specifying a port_name: rdev-url "" http
    local mp="$1"
    local port_name="$2"

    local pod_name=$(rdev-current "$mp")
    if [ -z "$pod_name" ]; then
        echo "Error: Could not find rdev for MP '${mp:-$(basename "$(pwd)")}'"
        return 1
    fi

    local info_output=$(rdev info "$pod_name")
    local host=$(echo "$info_output" | grep "^ Host" | awk -F '|' '{print $2}' | xargs)
    if [ -z "$host" ]; then
        echo "Error: Could not extract host from rdev info"
        return 1
    fi

    local port
    if [ -n "$port_name" ]; then
        port=$(echo "$info_output" | grep "Exposed port:" | grep "$port_name" | grep -oE "Exposed port: [0-9]+" | grep -oE "[0-9]+")
    else
        port=$(echo "$info_output" | grep "Exposed port:" | head -1 | grep -oE "Exposed port: [0-9]+" | grep -oE "[0-9]+")
    fi

    if [ -z "$port" ]; then
        if [ -n "$port_name" ]; then
            echo "Error: Could not find port '$port_name'"
        else
            echo "Error: Could not extract port from rdev info"
        fi
        return 1
    fi

    echo "http://${host}:${port}"
}
function rdev-open() {
    local url=$(rdev-url "$@")
    if [ $? -eq 0 ] && [ -n "$url" ]; then
        open "$url"
    else
        return 1
    fi
}


# ralph-cli: Ralph Wiggum loop runner for OpenSpec changes
alias ralph='uv run /Users/ekrogen/dev/ekrogen-misc/ralph-cli/ralph.py'

# rdev first-SSH-login finalize: runs the parts of setup that need the user's
# forwarded SSH agent or a logged-in gh. Triggered when the cfgli bare repo is
# missing (i.e., init_linkedin.sh deferred during rdev init). Runs in the
# background so the shell prompt is usable immediately; output tails to
# ~/.rdev_finish_setup.log. See ~/.cfg/scripts/rdev_finish_setup.sh. Also
# exposes a manual `rdev_finish_setup` command for re-running idempotently.
alias rdev_finish_setup='bash ~/.cfg/scripts/rdev_finish_setup.sh'
if [ -n "${RDEV_ID:-}" ] && [ ! -d "$HOME/.cfg.li.git" ] && [ -x "$HOME/.cfg/scripts/rdev_finish_setup.sh" ]; then
    echo "[rdev] cfgli bare repo missing; running rdev_finish_setup (synchronous, ~2-3m)."
    echo "[rdev] output below + in ~/.rdev_finish_setup.log"
    bash "$HOME/.cfg/scripts/rdev_finish_setup.sh"
    # rdev_finish_setup just installed ~/.local/bin/claude. If anything earlier
    # in this shell already invoked `claude`, zsh hashed it to the stale rdev
    # copy; drop the cache so the next call resolves via PATH again.
    hash -r
fi
