if [ "$(uname)" = "Darwin" ]; then
    OS_OSX=true
else
    OS_OSX=false
fi

alias cfgli='git --git-dir="$HOME/.cfg.li.git/" --work-tree="$HOME"'

# Google Workspace CLI (gws) — use Captain's shared OAuth app from LinkedIn KMS
# Uses Captain's Python keyring, which works on both macOS (Keychain) and Linux (plaintext file).
# captain-core moved to a versioned layout: ~/.cache/python-cli-runner/versions/captain-core/<v>/tool/captain-core/bin/python3
# Pick the newest version automatically so captain upgrades don't break this.
_captain_python="$(ls -d $HOME/.cache/python-cli-runner/versions/captain-core/*/tool/captain-core/bin/python3 2>/dev/null | sort -V | tail -1)"
if [ -x "$_captain_python" ]; then
    export GOOGLE_WORKSPACE_CLI_CLIENT_ID="$($_captain_python -c "import keyring,json; t=keyring.get_password('captain-google-docs','oauth2_token'); print(json.loads(t)['client_id'])" 2>/dev/null)"
    export GOOGLE_WORKSPACE_CLI_CLIENT_SECRET="$($_captain_python -c "import keyring,json; t=keyring.get_password('captain-google-docs','oauth2_token'); print(json.loads(t)['client_secret'])" 2>/dev/null)"
fi
unset _captain_python


alias tmux-local='tmux new -A -s local'

# Claude Code aliases
alias claude='claude --permission-mode auto'
alias alfred='claude --name alfred'

alias tlcrepl='java -cp /usr/local/opt/tlaplus-tools-1.8.0/tla2tools.jar tlc2.REPL'

if [ "$OS_OSX" = true ]; then
    export PATH=${PATH}:~/tools/kubectl-plugins
else
    # linuxbrew first so modern tools (tmux 3.6a, etc.) shadow the stale
    # /usr/local/bin copies baked into rdev images. ~/.local/bin carries the
    # native-installer Claude Code, which ships ahead of the baked version.
    export PATH="$HOME/.local/bin:/home/linuxbrew/.linuxbrew/bin:$HOME/.jenv/shims:/usr/local/bin:$PATH:$JAVA_HOME/bin"
    export PATH="$HOME/k8s-tools/kubectl-plugins:$PATH"

    # volta Node 20, direct tool-image bin dir.
    # LinkedIn's baseline image puts /export/content/linkedin/bin (Node 16) on
    # PATH ahead of /home/coder/.volta/bin, AND the volta shim itself seems to
    # honor that ordering — so even the shim's `node` reports v16. Point PATH
    # at the real Node 20 bin dir (which has concrete `node`/`npm`/`npx`
    # binaries, not shims) so `#!/usr/bin/env node` scripts like `npm` pick
    # Node 20 at exec time. Picks the newest installed 20.x automatically.
    _volta_node20_bin="$(ls -d $HOME/.volta/tools/image/node/20.*/bin 2>/dev/null | sort -V | tail -1)"
    [ -n "$_volta_node20_bin" ] && export PATH="$_volta_node20_bin:$PATH"
    unset _volta_node20_bin

    unset SSH_ASKPASS

    # On rdev, prefer the stable ~/.ssh/ssh_auth_sock symlink over whatever
    # /tmp/ssh-XXX/agent.PID path sshd forwarded *this* connection under.
    # The symlink is maintained by ~/.ssh/rc on every ssh login; using it
    # means existing tmux panes / long-running shells keep working after a
    # reconnect, instead of pointing at a dead socket from a since-exited
    # sshd. Re-evaluated every prompt so an attach that post-dates the
    # shell still gets fresh creds.
    _rdev_refresh_ssh_auth_sock() {
        [ -L ~/.ssh/ssh_auth_sock ] && export SSH_AUTH_SOCK=~/.ssh/ssh_auth_sock
    }
    _rdev_refresh_ssh_auth_sock
    if [ -n "$ZSH_VERSION" ]; then
        autoload -Uz add-zsh-hook
        add-zsh-hook precmd _rdev_refresh_ssh_auth_sock
    fi

    alias xclip="DISPLAY=:0 xclip"
    alias cb='$HOME/dev/configs/scripts/remote_clipboard_osx.sh macbook'
    alias copyback="DISPLAY=:0 xclip -o | cb"

    export KRB5CCNAME=FILE:/tmp/krb5cc_ekrogen
    alias kinit=/usr/bin/kinit
    alias klist=/usr/bin/klist
    alias kdestroy=/usr/bin/kdestroy
fi

